{
  "name": "msig",
  "version": "0.3.0",
  "description": "Browser-first JavaScript SDK for mutational signature analysis with mSigPortal data, plotting, and researcher workflow helpers.",
  "type": "module",
  "module": "./main.js",
  "exports": {
    ".": "./main.js"
  },
  "files": [
    "main.js",
    "mSigSDKScripts",
    "mSigPortalScripts",
    "examples",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "docs": "npm run docs:api && npm run docs:feature-reference",
    "docs:api": "node scripts/build-docs-api.mjs",
    "docs:feature-reference": "node scripts/build-feature-reference-html.mjs",
    "test:report-schema": "node scripts/validate-report-schema.mjs",
    "test:plot-context": "node scripts/verify-plot-publication-context.mjs",
    "verify:runtime-integrity": "node scripts/verify-bundled-runtime-integrity.mjs",
    "assets:notebook-previews": "node scripts/build-notebook-preview-assets.mjs",
    "notebooks:manifest": "node scripts/build-notebook-manifest.mjs",
    "serve:observable": "npm run notebooks:manifest && node scripts/serve-observable-sdk.mjs",
    "smoke:adapters": "node scripts/smoke-adapters.mjs",
    "smoke:guidance": "node scripts/smoke-guidance.mjs",
    "smoke:profile-conversions": "node scripts/smoke-profile-conversions.mjs",
    "smoke:strict-local": "node scripts/smoke-strict-local.mjs",
    "smoke:parallel-bootstrap": "node scripts/smoke-parallel-bootstrap.mjs",
    "smoke:tcga-contexts": "node scripts/smoke-tcga-contexts.mjs",
    "smoke:webr-adapters": "node scripts/smoke-webr-adapters-browser.mjs",
    "test:exact-adapters": "node scripts/verify-exact-adapter-boundaries.mjs",
    "manuscript:clean-experiments": "node scripts/manuscript/clean-experiments.mjs",
    "experiment:e1-zero-install": "node docs/manuscript/experiments/e1_zero_install_demo/code/run-zero-install-demo.mjs",
    "experiment:e2-r-setup": "Rscript scripts/manuscript/setup-e2-r-packages.R",
    "experiment:e2-adapter-fidelity": "node docs/manuscript/experiments/e2_adapter_fidelity/code/run-adapter-fidelity.mjs",
    "experiment:e3-reference-checks": "node docs/manuscript/experiments/e3_internal_reference_checks/code/run-internal-reference-checks.mjs",
    "experiment:e4-browser-benchmarks": "node docs/manuscript/experiments/e4_browser_runtime_benchmarks/code/run-browser-runtime-benchmarks.mjs",
    "experiment:bootstrap-hardware": "node scripts/manuscript/run-bootstrap-hardware-limits.mjs",
    "experiment:e6-compatibility": "node docs/manuscript/experiments/e6_cross_browser_compatibility/code/run-compatibility-checks.mjs",
    "experiment:all": "npm run experiment:e1-zero-install && npm run experiment:e2-adapter-fidelity && npm run experiment:e3-reference-checks && npm run experiment:e4-browser-benchmarks && npm run experiment:e6-compatibility",
    "assets:main-manuscript": "node scripts/manuscript/generate-main-assets.mjs",
    "assets:revision-figures": "node scripts/manuscript/generate-main-assets.mjs && node scripts/manuscript/export-main-figure-assets.mjs",
    "assets:bootstrap-hardware": "node scripts/manuscript/generate-bootstrap-hardware-assets.mjs",
    "assets:manuscript": "node scripts/manuscript/generate-assets.mjs && node scripts/manuscript/generate-main-assets.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/episphere/msig.git"
  },
  "keywords": [
    "mutational-signatures",
    "cancer-genomics",
    "msigportal",
    "bioinformatics"
  ],
  "author": "Aaron Ge",
  "license": "MIT",
  "homepage": "https://episphere.github.io/msig/",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.0.1",
    "d3": "^7.9.0",
    "documentation": "^14.0.3",
    "playwright-core": "^1.56.1"
  },
  "dependencies": {
    "build": "^0.1.4",
    "js-yaml": "^4.1.0"
  }
}
